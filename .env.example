# Copie este arquivo para .env para valores publicos/locais.
# Coloque chaves e tokens reais em .env.secrets.local (ignorado por Git/Docker).

# Server
PORT=3000
APP_BASE_URL=http://localhost:3000

# Database
LOCAL_DATA_ONLY=true
DATABASE_URL=mysql://root:root@127.0.0.1:3307/literary_canvas

# Auth / Security
JWT_SECRET=
ADMIN_EMAIL=admin@local.test
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# Client (Vite)
VITE_APP_ID=literary-canvas-local
VITE_API_URL=http://localhost:3000

# OAuth / External Services
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ENABLED=false
DEEPSEEK_TIMEOUT_SECONDS=900
DEEPSEEK_FREE_MODEL=
DEEPSEEK_ESSENTIAL_MODEL=
DEEPSEEK_ULTRA_MODEL=
DEEPSEEK_REVIEW_MODEL=
DEEPSEEK_INSPIRATION_MODEL=
DEEPSEEK_FREE_MAX_TOKENS=2000
DEEPSEEK_ESSENTIAL_MAX_TOKENS=6000
DEEPSEEK_ULTRA_MAX_TOKENS=12000
DEEPSEEK_REVIEW_MAX_TOKENS=4000
DEEPSEEK_INSPIRATION_MAX_TOKENS=3000

# RunPod 4090
RUNPOD_4090_ENABLED=false
RUNPOD_4090_DRY_RUN=false
RUNPOD_4090_ALLOWED_PLANS=essential
ALLOW_RUNPOD_IN_PRODUCTION=false
RUNPOD_API_KEY=
RUNPOD_4090_ENDPOINT=
RUNPOD_4090_MODEL=
RUNPOD_4090_TIMEOUT_SECONDS=600
